{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "Gateway.API",
    "Audience": "Gateway.Clients",
    "ExpiryMinutes": 30
  },
  "ReverseProxy": {
    "Routes": {
      "classifier-route": {
        "ClusterId": "classifier-cluster",
        "Match": {
          "Hosts": ["{APP_SUBDOMAIN}"],
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "classifier-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "{CLASSIFIER_BACKEND_URL}"
          }
        }
      }
    }
  }
}
