{
  "powershell.enableProfileLoading": false,
  // We have 3 Python projects (Level-1, Level-2, RAG-Service) but VS Code
  // keeps a single interpreter per workspace. Auto-activating that one in
  // every terminal is misleading — disable it and activate manually per
  // folder. (Each project's tasks.json already activates the right venv.)
  "python.terminal.activateEnvironment": false,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/Level-1-App/ai-classifier-app/backend",
    "${workspaceFolder}/Level-2-App/ai-writing-assistant/backend",
    "${workspaceFolder}/RAG-Service",
    // venv site-packages — Pylance needs these to resolve third-party
    // imports (fastapi, pydantic_settings, ...) without us forcing a
    // single workspace-wide interpreter.
    "${workspaceFolder}/Level-1-App/ai-classifier-app/backend/venv/Lib/site-packages",
    "${workspaceFolder}/Level-2-App/ai-writing-assistant/backend/venv/Lib/site-packages",
    "${workspaceFolder}/RAG-Service/venv/Lib/site-packages"
  ],
  "pylint.args": [
    "--disable=C0114,C0115,C0116",
    "--init-hook=import sys; sys.path.insert(0, r'${workspaceFolder}/RAG-Service'); sys.path.insert(0, r'${workspaceFolder}/RAG-Service/venv/Lib/site-packages'); sys.path.insert(0, r'${workspaceFolder}/Level-2-App/ai-writing-assistant/backend/venv/Lib/site-packages')"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/venv": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/venv/**": true
  },
  "markdownlint.config": {
    "MD020": false,
    "MD026": false,
    "MD034": false,
    "MD060": false,
    "MD040": false
  },
  "chat.restoreLastPanelSession": true,
  "chat.viewProgressBadge.enabled": true,
  "json.schemas": [
    {
      "fileMatch": ["tsconfig*.json"],
      "url": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/tsconfig.json"
    }
  ]
}
