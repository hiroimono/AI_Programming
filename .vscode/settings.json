{
  "powershell.enableProfileLoading": false,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/Level-1-App/ai-classifier-app/backend",
    "${workspaceFolder}/Level-2-App/ai-writing-assistant/backend"
  ],
  "pylint.args": ["--disable=C0114,C0115,C0116"],
  "search.exclude": {
    "**/node_modules": true,
    "**/venv": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/venv/**": true
  },
  "markdownlint.config": {
    "MD020": false,
    "MD026": false,
    "MD034": false,
    "MD060": false,
    "MD040": false
  },
  "chat.restoreLastPanelSession": true,
  "chat.viewProgressBadge.enabled": true,
  "json.schemas": [
    {
      "fileMatch": ["tsconfig*.json"],
      "url": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/tsconfig.json"
    }
  ]
}
