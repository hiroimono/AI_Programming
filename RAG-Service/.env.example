# Copy to .env and fill in real values. .env itself is gitignored.

# ─── Service identity ─────────────────────────────────────────
ENVIRONMENT=development

# ─── HTTP ─────────────────────────────────────────────────────
# Comma-separated; leave empty unless a browser truly needs to call
# rag-service directly (it shouldn't — always go through an app backend).
CORS_ORIGINS=

# ─── Database (Neon PostgreSQL) ───────────────────────────────
# Copy the connection string from the Neon Dashboard:
#   Role:     rag_service_user
#   Database: gatewaydb
# Paste it as-is (libpq format). Our code rewrites the prefix to
# `postgresql+asyncpg://` and strips the `?sslmode=...` query.
# Pool sizing tuned for Neon free tier; raise in production.
DATABASE_URL=postgresql://rag_service_user:PASSWORD@HOST.eu-central-1.aws.neon.tech/gatewaydb?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2

# ─── Phase 2+ will add: ───────────────────────────────────────
# OPENAI_API_KEY=sk-...
# RAG_SERVICE_SECRET=long-random-string-for-internal-jwt
# STORAGE_BACKEND=local            # local | r2 | hetzner
# STORAGE_LOCAL_PATH=./storage

