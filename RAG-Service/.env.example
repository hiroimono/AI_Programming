# Copy to .env and fill in real values. .env itself is gitignored.

# ─── Service identity ─────────────────────────────────────────
ENVIRONMENT=development

# ─── HTTP ─────────────────────────────────────────────────────
# Comma-separated; leave empty unless a browser truly needs to call
# rag-service directly (it shouldn't — always go through an app backend).
CORS_ORIGINS=

# ─── Phase 1+ will add: ───────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pwd@host/dbname
# OPENAI_API_KEY=sk-...
# RAG_SERVICE_SECRET=long-random-string-for-internal-jwt
# STORAGE_BACKEND=local            # local | r2 | hetzner
# STORAGE_LOCAL_PATH=./storage
