# .env.example — Copy to .env and fill in your values
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Phase 5: RAG integration ---
# Gateway JWT secret (must match Gateway/appsettings.Development.json Jwt:Secret)
# Required for /api/documents endpoints; optional for /api/chat (falls back
# to anonymous mode if missing).
GATEWAY_JWT_SECRET=
GATEWAY_JWT_ISSUER=Gateway.API
GATEWAY_JWT_AUDIENCE=Gateway.Clients

# rag-service base URL (local dev defaults to 8100)
RAG_SERVICE_URL=http://localhost:8100
# Shared HS256 secret with rag-service's INTERNAL_JWT_SECRET
RAG_INTERNAL_JWT_SECRET=
# App id sent in the internal JWT (rag-service maps this to its level2 schema)
RAG_APP_ID=level-2-writer
